# Roomz environment variables. Copy this file to .env and adjust as needed.
# .env is loaded automatically at startup.

# Base path for library folders. All added library paths must be under this directory.
# Leave unset to use the project data/ directory. Set to allow external paths, e.g.:
# ROOMZ_LIBRARY_BASE=/mnt/media/music
# ROOMZ_LIBRARY_BASE=./data
# ROOMZ_LIBRARY_BASE=
